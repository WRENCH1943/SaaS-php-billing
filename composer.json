{
    "name": "wrench1943/saas-php-billing",
    "description": "Multi-Tenant SaaS Billing & Subscription Engine",
    "type": "project",
    "require": {
        "php": "^8.1",
        "doctrine/orm": "^2.14",
        "doctrine/migrations": "^3.5",
        "php-di/php-di": "^7.0",
        "guzzlehttp/guzzle": "^7.5",
        "ramsey/uuid": "^4.7",
        "symfony/console": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Billing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Billing\\Tests\\": "tests/"
        }
    }
}